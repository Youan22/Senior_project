{
  "name": "servicematch",
  "version": "1.0.0",
  "description": "Video-first home services marketplace",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && npm run dev",
    "client:dev": "cd client && npm run dev",
    "mobile:dev": "cd mobile && npm run start",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install && cd .. && node scripts/install-mobile-if-present.cjs"
  },
  "keywords": [
    "home-services",
    "marketplace",
    "video",
    "matching"
  ],
  "author": "ServiceMatch Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
