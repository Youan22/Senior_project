# Copy to repo root as `.env` (server loads this path).
# cp .env.example .env

# --- Database (required for API + migrations) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=servicematch_dev
# Use a PostgreSQL role that exists on your machine (`psql -c '\\du'`).
# Linux packages often use `postgres`; macOS Homebrew may use your macOS username instead.
DB_USER=postgres
DB_PASSWORD=

# --- Auth (required) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Server ---
PORT=5000
NODE_ENV=development

# Browser origin(s) for CORS / Socket.io. In dev, localhost ports 3000–3010 are also allowed.
CLIENT_URL=http://localhost:3000
# Optional: comma-separated extra origins (e.g. staging URL)
# CLIENT_URLS=

# --- Client (Next.js) — must be prefixed NEXT_PUBLIC_ to reach the browser ---
# All fetch/socket URLs in the web app use this (see client/lib/apiUrl.ts).
# Defaults to http://localhost:5000 if unset.
NEXT_PUBLIC_API_URL=http://localhost:5000

# --- Stripe (required for payment routes to call Stripe; use test keys in dev) ---
# STRIPE_SECRET_KEY=sk_test_...

# --- AWS S3 (not wired in all code paths yet; set when enabling video uploads) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2
# AWS_S3_BUCKET=
